topology = mesh;
k = 3;
n = 2;
routing_function = adaptive_xy_yx;
num_vcs     = 4;
vc_buf_size = 8;
wait_for_tail_credit = 1;
vc_allocator = islip;
sw_allocator = islip;
alloc_iters  = 1;
credit_delay   = 2;
routing_delay  = 0;
vc_alloc_delay = 1;
sw_alloc_delay = 1;
input_speedup     = 2;
output_speedup    = 1;
internal_speedup  = 1.0;
noq=0;
traffic = uniform;
packet_size = {5,8};
injection_rate = {0.02,0.02};
injection_process = bernoulli;
sim_type = latency;
classes = 2;
print_csv_results = 0;
watch_flits = {0};
viewer_trace = 1;
network_file = network_file;
arb_type=priority;
speculative=0;
stats_out=stats.txt;
print_activity = 0;
seed=2;
sim_count = 10000;
warmup_cycles = 1000;
sim_cycles = 10000;
used_credits_out = used_credits_out.txt;
free_credits_out = free_credits_out.txt;
max_credits_out = max_credits_out.txt;

{
  "name": "openclaw-sdk",
  "version": "2026.3.19",
  "description": "OpenClaw SDK for TypeScript/JavaScript",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./protocol": {
      "types": "./dist/esm/protocol.d.ts",
      "import": "./dist/esm/protocol.js",
      "require": "./dist/cjs/protocol.js",
      "default": "./dist/esm/protocol.js"
    },
    "./browser": {
      "default": "./dist/browser/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "esm": [
        "dist/esm/index.d.ts"
      ],
      "default": [
        "dist/esm/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "check:circular": "madge src/ --circular --extensions ts",
    "docs": "typedoc",
    "docs:check": "typedoc --help > /dev/null && echo '✓ TypeDoc configuration valid'",
    "prepublishOnly": "npm run build",
    "changelog": "git-cliff --output CHANGELOG.md",
    "changelog:unreleased": "git-cliff --unreleased",
    "changelog:preview": "git-cliff --unreleased",
    "prepare": "husky"
  },
  "dependencies": {
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.0",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vitest/coverage-v8": "4.1.0",
    "esbuild": "0.27.4",
    "eslint": "10.0.3",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "madge": "8.0.0",
    "prettier": "3.8.1",
    "typedoc": "0.28.17",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "keywords": [
    "openclaw",
    "sdk"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/frisbee-ai/openclaw-sdk-typescript"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}

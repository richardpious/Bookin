{
  "name": "bookin-plugin-tool-approval",
  "version": "1.0.1",
  "description": "Requires user approval before sensitive tool execution",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --format=esm --external:openclaw/plugin-sdk/tool-plugin --external:openclaw/plugin-sdk/hooks"
  },
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "hooks": true
  }
}
